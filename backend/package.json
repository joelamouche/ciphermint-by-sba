{
  "name": "ciphermint-backend",
  "version": "1.0.0",
  "description": "Backend API for CipherMint KYC integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION_TESTS_ENABLED=true vitest run --config=vitest.integration.config.ts",
    "test:attest:manual": "MANUAL_ATTEST_ENABLED=true vitest run --config=vitest.integration.config.ts src/lib/__tests__/attestIdentity.manual.integration.test.ts",
    "test:vault:smoke:manual": "MANUAL_VAULT_SMOKE_ENABLED=true vitest run --config=vitest.integration.config.ts src/lib/__tests__/vaultDeposit.manual.integration.test.ts",
    "deploy:heroku": "bash scripts/deploy-heroku.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@zama-fhe/relayer-sdk": "^0.4.2",
    "express": "^4.21.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "siwe": "^2.1.4",
    "ethers": "^6.13.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.7.5",
    "prisma": "^5.19.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
